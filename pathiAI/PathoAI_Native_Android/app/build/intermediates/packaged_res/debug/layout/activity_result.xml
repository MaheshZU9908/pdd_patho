<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Report Header Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CLINICAL PATHOLOGY REPORT"
            android:textColor="@color/primary_dark"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/tv_report_datetime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Date of Analysis: 2026-05-24 09:20"
            android:textColor="#666666"
            android:textSize="12sp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp" />

        <!-- Patient Metadata Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="16dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@color/primary_dark">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:id="@+id/tv_report_patient_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Emily Davis"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/tv_report_patient_id"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PID-1024"
                        android:textColor="@color/primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"/>
                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#33FFFFFF"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tv_report_patient_meta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Age: 31 yrs | Gender: Female | Contact: +1-555-0111"
                    android:textColor="@color/white"
                    android:alpha="0.8"
                    android:textSize="13sp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Biopsy Slide & Highlight Frame -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="16dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tissue Pathology Scan &amp; Detection Heatmap"
                        android:textColor="@color/text_main"
                        android:textStyle="bold"
                        android:textSize="14sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tap to Zoom"
                        android:textColor="@color/primary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_alignParentEnd="true"/>
                </RelativeLayout>

                <FrameLayout
                    android:id="@+id/layout_result_image_container"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:background="#1E293B"
                    android:clickable="true"
                    android:focusable="true">
                    
                    <ImageView
                        android:id="@+id/iv_result_biopsy_image"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="fitCenter"
                        android:contentDescription="Biopsy Scan Highlight Overlay" />
                </FrameLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- AI Quantitative Metrics Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="16dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Deep Learning Diagnostic Metrics"
                    android:textColor="@color/text_main"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:layout_marginBottom="12dp"/>

                <!-- Row 1: Disease Prediction -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Disease Prediction"
                        android:textColor="#555555" />
                    <TextView
                        android:id="@+id/tv_res_disease"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Oral Squamous Cell Carcinoma"
                        android:textColor="@color/text_main"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Row 2: AI Confidence -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="AI Confidence Score"
                        android:textColor="#555555" />
                    <TextView
                        android:id="@+id/tv_res_confidence"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="97.8%"
                        android:textColor="@color/primary"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Row 3: Metastasis Risk -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Nodal Metastasis Risk"
                        android:textColor="#555555" />
                    <TextView
                        android:id="@+id/tv_res_metastasis"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="94% (Critical)"
                        android:textColor="@color/danger"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Row 4: Tumor Budding -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Tumor Budding"
                        android:textColor="#555555" />
                    <TextView
                        android:id="@+id/tv_res_budding"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Grade 3 (High)"
                        android:textColor="@color/danger"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Row 5: Stromal Inflammation -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Stromal Inflammation Level"
                        android:textColor="#555555" />
                    <TextView
                        android:id="@+id/tv_res_inflammation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Severe"
                        android:textColor="@color/text_main"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Row 6: Invasion Depth -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Invasion Depth Measurement"
                        android:textColor="#555555" />
                    <TextView
                        android:id="@+id/tv_res_invasion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5.2 mm"
                        android:textColor="@color/text_main"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Row 7: Report Status -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Report Case Status"
                        android:textColor="#555555" />
                    <TextView
                        android:id="@+id/tv_res_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DIAGNOSED / UNVERIFIED"
                        android:textColor="@color/primary"
                        android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- AI Narrative Summary Box -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="16dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AI Clinical Interpretation &amp; Findings"
                    android:textColor="@color/text_main"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tv_res_interpretation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Microscopic tissue scan displays sheets of malignant pleomorphic squamous cells invading deeply into the vascular stroma. High density of tumor budding (14 buds/HPF) at the peripheral margin. Marked peritumoral stromal inflammation present."
                    android:textColor="#334155"
                    android:lineSpacingExtra="4dp"
                    android:textSize="13sp"
                    android:background="#F1F5F9"
                    android:padding="12dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Doctor Notes & Actions Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="24dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Doctor's Clinical Notes &amp; Recommendations"
                    android:textColor="@color/text_main"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp"/>

                <EditText
                    android:id="@+id/et_report_doctor_notes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minLines="3"
                    android:hint="Add notes regarding staging, treatment path, or recommendations..."
                    android:gravity="top|start"
                    android:padding="12dp"
                    android:textSize="14sp"
                    android:textColor="@color/text_main"
                    android:background="@drawable/input_bg"
                    android:layout_marginBottom="16dp" />

                <!-- Action Button Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    
                    <Button
                        android:id="@+id/btn_save_report_changes"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:text="Save Findings"
                        android:textAllCaps="false"
                        android:backgroundTint="@color/primary"
                        android:textColor="@color/white"
                        android:textSize="14sp"/>

                    <Button
                        android:id="@+id/btn_download_report_pdf"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1.2"
                        android:layout_marginStart="6dp"
                        android:text="Export PDF Report"
                        android:textAllCaps="false"
                        android:backgroundTint="@color/success"
                        android:textColor="@color/white"
                        android:textSize="14sp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Back Button -->
        <Button
            android:id="@+id/btn_report_back"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Back to Clinical Dashboard"
            android:textAllCaps="false"
            android:backgroundTint="@color/white"
            android:textColor="@color/primary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

    </LinearLayout>
</ScrollView>
