<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top Row: Patient Name & Action Buttons -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tv_patient_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="John Doe"
                android:textColor="@color/text_main"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@id/actions_layout" />

            <LinearLayout
                android:id="@+id/actions_layout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true">

                <ImageView
                    android:id="@+id/btn_edit_patient"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@android:drawable/ic_menu_edit"
                    android:layout_marginEnd="16dp"
                    android:contentDescription="Edit Patient"
                    app:tint="@color/primary"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="4dp" />

                <ImageView
                    android:id="@+id/btn_delete_patient"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@android:drawable/ic_menu_delete"
                    android:contentDescription="Delete Patient"
                    app:tint="@color/danger"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="4dp" />
            </LinearLayout>
        </RelativeLayout>

        <!-- Sub Row: ID and Age/Gender -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_patient_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PID-1021"
                android:textColor="@color/primary"
                android:textStyle="bold"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" • "
                android:textColor="#888888" />

            <TextView
                android:id="@+id/tv_patient_age_gender"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="54 yrs / Male"
                android:textColor="#555555"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Diagnosis Field -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Active Diagnosis: "
                android:textColor="#555555"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_patient_diagnosis"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Invasive Carcinoma"
                android:textColor="@color/text_main"
                android:textStyle="bold"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Bottom Row: Contact Info & Risk Level Badge -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <TextView
                android:id="@+id/tv_patient_contact"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Contact: +1-555-0192"
                android:textColor="#777777"
                android:textSize="13sp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true" />

            <TextView
                android:id="@+id/tv_patient_status_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="High Risk"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/input_bg"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:layout_alignParentEnd="true"
                android:gravity="center" />
        </RelativeLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
